{
  "name": "eventfilm",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "client",
    "server",
    "apps/mobile",
    "packages/shared",
    "packages/api-client"
  ],
  "scripts": {
    "dev:web": "npm run dev -w client",
    "dev:api": "npm run dev -w server",
    "dev:mobile": "npm run start -w @eventfilm/mobile",
    "check": "npm run check:shared && npm run check:api-client && npm run check:web && npm run check:api && npm run check:mobile",
    "check:web": "npm run build -w client",
    "build:web": "npm run build -w client",
    "check:api": "npm run build -w server",
    "build:api": "npm run build -w server",
    "check:shared": "npm run typecheck -w @eventfilm/shared",
    "check:api-client": "npm run typecheck -w @eventfilm/api-client",
    "check:mobile": "npm run typecheck -w @eventfilm/mobile",
    "lint:mobile": "npm run lint -w @eventfilm/mobile"
  }
}
