{
  "name": "eventfilm",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "client",
    "server",
    "apps/mobile",
    "packages/shared",
    "packages/api-client"
  ],
  "scripts": {
    "dev:web": "npm run dev -w client",
    "dev:api": "npm run dev -w server",
    "dev:mobile": "npm run mobile:start",
    "mobile:start": "expo start apps/mobile",
    "mobile:start:clear": "expo start apps/mobile --clear",
    "expo:start": "npm run mobile:start",
    "check": "npm run check:shared && npm run check:api-client && npm run check:web && npm run check:api && npm run check:mobile",
    "check:web": "npm run build -w client",
    "build:web": "npm run build -w client",
    "check:api": "npm run build -w server",
    "build:api": "npm run build -w server",
    "test:server": "npm run test -w server",
    "check:shared": "npm run typecheck -w @eventfilm/shared",
    "test:shared": "npm run test -w @eventfilm/shared",
    "check:api-client": "npm run typecheck -w @eventfilm/api-client",
    "check:mobile": "npm run typecheck -w @eventfilm/mobile",
    "lint:mobile": "npm run lint -w @eventfilm/mobile",
    "preflight": "node scripts/preflight.js",
    "smoke:browser": "playwright test",
    "smoke:storage": "npm run storage:smoke -w server",
    "smoke:deployed:api": "node scripts/deployed-smoke-api.js",
    "smoke:deployed:browser": "node scripts/deployed-smoke-browser.js",
    "smoke:deployed:storage": "node scripts/deployed-smoke-storage.js",
    "smoke:deployed:all": "node scripts/deployed-smoke-all.js",
    "auth:smoke": "node scripts/auth-smoke.js",
    "dev-host:reset": "npm run reset:dev-host -w server",
    "demo:seed": "npm run seed:beta-demo -w server",
    "demo:cleanup": "npm run seed:beta-demo -w server -- --cleanup"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0"
  }
}
