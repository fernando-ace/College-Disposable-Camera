DATABASE_URL="postgresql://postgres:postgres@localhost:5432/eventfilm?schema=public"
NODE_ENV="development"
JWT_SECRET="replace-with-a-long-random-secret"
ANALYTICS_SALT="replace-with-a-long-random-analytics-salt"
# Comma-separated founder/admin host emails allowed to access /dashboard/founder.
# Leave empty to deny founder dashboard access safely.
FOUNDER_EMAILS="you@example.com"
CLIENT_URL="http://localhost:5173"
SERVER_URL="http://localhost:4000"
# Preview/production aliases. Keep CLIENT_URL/SERVER_URL or use these names on hosts that prefer public URL naming.
WEB_PUBLIC_URL="http://localhost:5173"
API_PUBLIC_URL="http://localhost:4000"
# Optional extra browser origins allowed by CORS, comma-separated. Never use "*" in production.
CLIENT_ORIGINS=""
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-your-service-role-key"
SUPABASE_STORAGE_BUCKET="event-photos"
MAX_FILE_SIZE_MB="10"
PORT="4000"
