generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChallengeType {
  COLOR_HUNT
  PHOTO_SCAVENGER_HUNT
  EVENT_AWARDS
  MEMORY_CAPSULE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  events       Event[]
  eventAccesses EventAccess[]
  hostEventFeedback HostEventFeedback[]
}

model Event {
  id                 String   @id @default(cuid())
  hostId             String
  name               String
  description        String?
  slug               String   @unique
  eventDate          DateTime
  revealAt           DateTime
  photoLimitPerGuest Int
  eventTemplateSlug  String?
  promptPackSlug     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  host   User    @relation(fields: [hostId], references: [id], onDelete: Cascade)
  eventAccesses EventAccess[]
  guests Guest[]
  photos Photo[]
  challenges EventChallenge[]
  photoVotes         PhotoVote[]
  photoLikes         PhotoLike[]
  hostFeedback       HostEventFeedback[]

  @@index([hostId])
}

model EventAccess {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId])
  @@index([userId])
}

model EventChallenge {
  id           String        @id @default(cuid())
  eventId      String
  type         ChallengeType
  title        String
  instructions String
  config       Json
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  event        Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participants ChallengeParticipant[]
  photos       Photo[]                @relation("PhotoChallenge")

  @@index([eventId])
  @@index([eventId, isActive])
}

model ChallengeParticipant {
  id               String   @id @default(cuid())
  eventChallengeId String
  displayName      String
  colorName        String
  colorHex         String
  colorSlug        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  eventChallenge EventChallenge @relation(fields: [eventChallengeId], references: [id], onDelete: Cascade)
  photos         Photo[]

  @@index([eventChallengeId])
  @@index([eventChallengeId, colorSlug])
}

model Guest {
  id        String   @id @default(cuid())
  eventId   String
  nickname  String
  clientId  String
  createdAt DateTime @default(now())

  event  Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  photos Photo[]

  @@unique([eventId, clientId])
  @@index([eventId])
}

model Photo {
  id               String    @id @default(cuid())
  eventId          String
  guestId          String
  filePath         String
  originalFilename String
  mimeType         String
  sizeBytes        Int
  createdAt        DateTime  @default(now())
  deletedAt        DateTime?
  challengeId      String?
  challengeParticipantId String?
  challengeColorName     String?
  challengePromptId      String?
  challengePromptText    String?
  challengeItemId        String?
  challengeItemLabel     String?
  challengeItemKind      String?
  isFeatured             Boolean               @default(false)
  featuredAt             DateTime?

  event                Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guest                Guest                 @relation(fields: [guestId], references: [id], onDelete: Cascade)
  challenge            EventChallenge?       @relation("PhotoChallenge", fields: [challengeId], references: [id], onDelete: SetNull)
  challengeParticipant ChallengeParticipant? @relation(fields: [challengeParticipantId], references: [id], onDelete: SetNull)
  votes                PhotoVote[]
  likes                PhotoLike[]

  @@index([eventId])
  @@index([eventId, isFeatured])
  @@index([guestId])
  @@index([challengeId])
  @@index([challengeParticipantId])
  @@index([challengePromptId])
  @@index([challengeItemId])
}

model PhotoVote {
  id              String   @id @default(cuid())
  eventId         String
  photoId         String
  challengeItemId String
  guestClientId   String
  createdAt       DateTime @default(now())

  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  photo           Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([eventId, challengeItemId, guestClientId])
  @@index([eventId, photoId])
  @@index([eventId, challengeItemId])
}

model PhotoLike {
  id            String   @id @default(cuid())
  eventId       String
  photoId       String
  guestClientId String
  createdAt     DateTime @default(now())

  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  photo         Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([eventId, photoId, guestClientId])
  @@index([eventId, photoId])
  @@index([eventId, guestClientId])
}

model AnalyticsEvent {
  id              String   @id @default(cuid())
  name            String
  source          String
  path            String?
  userId          String?
  eventId         String?
  eventSlug       String?
  anonymousIdHash String?
  metadata        Json
  createdAt       DateTime @default(now())

  @@index([name])
  @@index([createdAt])
  @@index([userId])
  @@index([eventId])
}

model HostEventFeedback {
  id             String    @id @default(cuid())
  eventId        String
  hostId         String
  kind           String    @default("post_event")
  issueArea      String?
  outcome        String?
  repeatIntent   String?
  guestConfusion String?
  featureRequest String?
  note           String?
  skippedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  event          Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  host           User      @relation(fields: [hostId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([hostId])
  @@index([eventId, hostId])
}
